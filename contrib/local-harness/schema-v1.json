{
  "type": "object",
  "properties": {
    "schema_version": { "type": "integer", "enum": [1] },
    "disposition": { "type": "string", "enum": ["findings", "no_findings"] },
    "reason": { "type": ["string", "null"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "artifact_kind": {
            "type": "string",
            "enum": [
              "research", "spec", "roadmap", "test", "task", "todo",
              "plan", "report", "review", "ship-record", "gate-report"
            ]
          },
          "project": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "body": { "type": "string", "minLength": 1 },
          "source_fragment_indices": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 1
          },
          "relations": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["relates_to"] },
                    "target_title": { "type": "string", "minLength": 1 }
                  },
                  "required": ["type", "target_title"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["mentions"] },
                    "entity": { "type": "string", "minLength": 1 }
                  },
                  "required": ["type", "entity"],
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "required": [
          "title", "artifact_kind", "project", "tags", "body",
          "source_fragment_indices", "relations"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["schema_version", "disposition", "reason", "findings"],
  "additionalProperties": false
}
